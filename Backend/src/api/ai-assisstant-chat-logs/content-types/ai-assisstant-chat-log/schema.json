{
  "kind": "collectionType",
  "collectionName": "ai-assisstant-chat-logs",
  "info": {
    "singularName": "ai-assisstant-chat-log",
    "pluralName": "ai-assisstant-chat-logs",
    "displayName": "aiAssistantChatLogs"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "userId": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "plugin::users-permissions.user"
    },
    "userRole": {
      "type": "enumeration",
      "enum": [
        "player",
        "manager"
      ]
    },
    "provider": {
      "type": "string"
    },
    "model": {
      "type": "string"
    },
    "userMessage": {
      "type": "text"
    },
    "aiReply": {
      "type": "text"
    },
    "toolsUsed": {
      "type": "json"
    },
    "actionsTaken": {
      "type": "json"
    },
    "tokensUsed": {
      "type": "biginteger"
    },
    "processingMs": {
      "type": "decimal"
    },
    "success": {
      "type": "boolean"
    },
    "errorMessage": {
      "type": "text"
    },
    "sessionId": {
      "type": "string"
    },
    "createdAtTimestamp": {
      "type": "datetime"
    }
  }
}
